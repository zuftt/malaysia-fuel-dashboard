# Copy to .env and fill in. Never commit .env.

# --- Auth (REQUIRED) ---
# JWT signing secret. The API will refuse to start without this.
# Generate one with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=
# How long an issued JWT lives. Default 60 minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Monitoring (Sentry) ---
# Get DSN from https://sentry.io (free account, 5000 errors/month)
# Leave empty to disable error tracking
SENTRY_DSN=
ENVIRONMENT=development

# --- FX (ASEAN USD conversion). Fixer.io: https://data.fixer.io/documentation ---
# GET https://data.fixer.io/api/latest?access_key=YOUR_KEY&symbols=USD,MYR,... (default EUR base; we convert to per-USD).
# When set, the backend calls Fixer.io at most once per UTC day and caches JSON under backend/.cache/ (see FIXER_FX_CACHE_PATH).
# Leave unset to use exchangerate.host on each request instead.
FIXER_ACCESS_KEY=
# Legacy alias (same value as FIXER_ACCESS_KEY if you already use this name):
# FIXER_FX_API_KEY=
# Optional override for the daily Fixer cache file (default: backend/.cache/fixer_fx_cache.json).
# FIXER_FX_CACHE_PATH=

# --- Firecrawl (weekly ASEAN page snapshots: python -m app.api.scrape) ---
FIRECRAWL_API_KEY=

# Latest pump prices (GET /api/v1/prices/pump-stations → “Latest Pump Prices” on the site). Examples:
# MY_PUMP_PRICES=https://www.shell.com.my/fuels-oils-and-lubricants/shell-fuels/fuelprice.html
#   → loads fuelprice.model.json, then Shell's fuel-price-update-malaysia.xlsx (Peninsular + regional column).
#   Regional column values are emitted as separate Sabah and Sarawak rows (Shell file may label that column *East Malaysia*). HTML fallback if xlsx fails.
# MY_PUMP_PRICES=https://www.motorist.my/petrol-prices
# Optional Firecrawl cache window for non-Shell URLs only (ms). Default 172800000 = 48h.
# MY_PUMP_MAX_AGE_MS=172800000
# Optional: Petron Malaysia homepage for RON 100 (Blaze 100) — fetched only on the same live-scrape
# schedule as above (not on every page load). Example:
# MY_PUMP_PRICES2=https://www.petron.com.my/
# API also writes JSON under backend/.cache/pump_stations.json and only runs live scrapes on
# Thursday (Malaysia time), at most once that day. Override path:
# PUMP_STATIONS_CACHE_PATH=/tmp/pump_stations.json

# Optional: one full URL per country (https://...). Omitted countries are skipped.
# Replace with official or licensed pages once you decide per country.
# ASEAN_FIRECRAWL_URL_MY=
# ASEAN_FIRECRAWL_URL_SG=
# ASEAN_FIRECRAWL_URL_TH=
# ASEAN_FIRECRAWL_URL_ID=
# ASEAN_FIRECRAWL_URL_BN=
# ASEAN_FIRECRAWL_URL_PH=

# Legacy alias for Indonesia only (used if ASEAN_FIRECRAWL_URL_ID is unset)
# INDO=https://www.example.com/fuel-prices
